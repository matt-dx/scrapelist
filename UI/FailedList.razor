@using RazorConsole.Components
@using Scrapelist.Models

@if (Items.Count > 0)
{
    <Panel Title="@($"Failed ({Items.Count})")" BorderColor="@Color.Red">
        <Rows>
            @foreach (var item in Items)
            {
                <Markup Content="@GetItemText(item)" Foreground="@Color.Red" />
            }
        </Rows>
    </Panel>
}

@code {
    [Parameter] public IReadOnlyList<DownloadItem> Items { get; set; } = [];

    private static string GetItemText(DownloadItem item)
    {
        var title = item.Title;
        if (title.Length > 50)
            title = title[..47] + "...";
        var retries = $"({item.FailedAttempts}/{item.MaxRetries} attempts)";
        var error = !string.IsNullOrEmpty(item.ErrorMessage) ? $" - {item.ErrorMessage}" : "";
        return $"  {title} {retries}{error}";
    }
}
