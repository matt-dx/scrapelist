@using RazorConsole.Components
@using Scrapelist.Models

<Panel Title="Scrapelist" BorderColor="@Color.Blue">
    <Rows>
        <Markup Content="@($"Source: {SourceUri}")" Foreground="@Color.Grey" />
        <Markup Content="@GetSummary()" Foreground="@Color.White" />
    </Rows>
</Panel>

@code {
    [Parameter] public string SourceUri { get; set; } = "";
    [Parameter] public DownloadType DownloadType { get; set; }
    [Parameter] public IReadOnlyList<DownloadItem> Items { get; set; } = [];

    private string GetSummary()
    {
        var total = Items.Count;
        var completed = Items.Count(i => i.Status is DownloadStatus.Completed or DownloadStatus.Skipped);
        var downloading = Items.Count(i => i.Status == DownloadStatus.Downloading);
        var transcoding = Items.Count(i => i.Status == DownloadStatus.Transcoding);
        var failed = Items.Count(i => i.Status == DownloadStatus.Failed);
        var pending = Items.Count(i => i.Status == DownloadStatus.Pending);

        return $"Type: {DownloadType} | Total: {total} | Done: {completed} | Active: {downloading} | Transcoding: {transcoding} | Pending: {pending} | Failed: {failed}";
    }
}
