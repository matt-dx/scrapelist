@using RazorConsole.Components
@using Scrapelist.Models

@if (Items.Count > 0)
{
    <Panel Title="@($"Transcoding ({Items.Count})")" BorderColor="@Color.Cyan1">
        <Rows>
            @foreach (var item in Items)
            {
                <Markup Content="@GetItemText(item)" Foreground="@Color.Cyan1" />
            }
        </Rows>
    </Panel>
}

@code {
    [Parameter] public IReadOnlyList<DownloadItem> Items { get; set; } = [];

    private static string GetItemText(DownloadItem item)
    {
        var title = item.Title;
        if (title.Length > 50)
            title = title[..47] + "...";
        return $"  {title}  Transcoding...";
    }
}
