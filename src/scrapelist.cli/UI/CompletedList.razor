@using RazorConsole.Components
@using Scrapelist.Models

@if (Items.Count > 0)
{
    <Panel Title="@($"Completed ({Items.Count})")" BorderColor="@Color.Green">
        <Rows>
            @foreach (var item in Items.TakeLast(10))
            {
                <Markup Content="@GetItemText(item)" Foreground="@Color.Green" />
            }
            @if (Items.Count > 10)
            {
                <Markup Content="@($"  ... and {Items.Count - 10} more (showing last 10)")" Foreground="@Color.Grey" />
            }
        </Rows>
    </Panel>
}

@code {
    [Parameter] public IReadOnlyList<DownloadItem> Items { get; set; } = [];

    private static string GetItemText(DownloadItem item)
    {
        var status = item.Status == DownloadStatus.Skipped ? "SKIP" : "OK";
        var title = item.Title;
        if (title.Length > 60)
            title = title[..57] + "...";
        return $"  [{status}] {title}";
    }
}
