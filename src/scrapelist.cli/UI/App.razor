@using Microsoft.AspNetCore.Components
@using RazorConsole.Components
@using Scrapelist.Models
@using Scrapelist.Services
@using Microsoft.Extensions.Hosting
@inject DownloadManager Manager
@inject IHostApplicationLifetime AppLifetime

<Rows>
    <HeaderSection SourceUri="@Manager.SourceUri"
                   DownloadType="@Manager.DownloadType"
                   Items="@Manager.AllItems" />

    <ActiveDownloads Items="@GetItemsByStatus(DownloadStatus.Downloading)" />

    <TranscodingList Items="@GetItemsByStatus(DownloadStatus.Transcoding)" />

    <PendingList Items="@GetItemsByStatus(DownloadStatus.Pending)" />

    <CompletedList Items="@GetCompletedAndSkipped()" />

    <FailedList Items="@GetItemsByStatus(DownloadStatus.Failed)" />

    @if (Manager.IsCompleted)
    {
        <Panel Title="Status" BorderColor="@Color.Green">
            <Markup Content="All downloads complete!" Foreground="@Color.Green" />
        </Panel>
    }
</Rows>

@code {
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        _cts = new CancellationTokenSource();

        // Periodic UI refresh (250ms) — replaces fragile event-driven rendering
        // that would freeze when InvokeAsync threw under high concurrency
        _ = Task.Run(async () =>
        {
            using var timer = new PeriodicTimer(TimeSpan.FromMilliseconds(250));
            while (await timer.WaitForNextTickAsync(_cts.Token))
            {
                try
                {
                    await InvokeAsync(StateHasChanged);
                }
                catch (OperationCanceledException) { break; }
                catch { /* render error — timer will retry next tick */ }
            }
        });

        try
        {
            await Manager.InitializeAsync(_cts.Token);
            _ = Task.Run(async () =>
            {
                try
                {
                    await Manager.RunAsync(_cts.Token);
                }
                catch (OperationCanceledException) { }
                catch (Exception ex)
                {
                    Console.Error.WriteLine($"Fatal error: {ex.Message}");
                }

                // Allow final UI render to show completion status, then exit
                await Task.Delay(2000);
                _cts?.Cancel();
                AppLifetime.StopApplication();
            });
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Initialization failed: {ex.Message}");
        }
    }

    private IReadOnlyList<DownloadItem> GetItemsByStatus(DownloadStatus status)
    {
        return Manager.AllItems.Where(i => i.Status == status).ToList();
    }

    private IReadOnlyList<DownloadItem> GetCompletedAndSkipped()
    {
        return Manager.AllItems
            .Where(i => i.Status is DownloadStatus.Completed or DownloadStatus.Skipped)
            .ToList();
    }
}
