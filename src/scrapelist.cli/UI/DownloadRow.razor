@using RazorConsole.Components
@using Scrapelist.Models

<Columns>
    <Markup Content="@GetTitle()" Foreground="@Color.White" />
    <Markup Content="@GetProgressBar()" Foreground="@Color.Yellow" />
    <Markup Content="@GetTimingInfo()" Foreground="@Color.Grey" />
</Columns>

@code {
    [Parameter] public required DownloadItem Item { get; set; }

    private string GetTitle()
    {
        var title = Item.Title;
        if (title.Length > 35)
            title = title[..32] + "...";
        return title.PadRight(35);
    }

    private string GetProgressBar()
    {
        const int barWidth = 20;
        var filled = (int)(Item.Progress * barWidth);
        var empty = barWidth - filled;

        var pct = (int)(Item.Progress * 100);
        var bar = new string('#', filled) + new string('-', empty);
        return $"[{bar}] {pct,3}%";
    }

    private string GetTimingInfo()
    {
        var elapsed = FormatTime(Item.Elapsed);
        var remaining = Item.EstimatedRemaining.HasValue
            ? $" / ~{FormatTime(Item.EstimatedRemaining.Value)}"
            : "";

        var size = Item.TotalBytes > 0
            ? $" | {FormatBytes(Item.DownloadedBytes)}/{FormatBytes(Item.TotalBytes)}"
            : "";

        return $"{elapsed}{remaining}{size}";
    }

    private static string FormatTime(TimeSpan ts)
    {
        return ts.Hours > 0
            ? $"{ts.Hours}:{ts.Minutes:D2}:{ts.Seconds:D2}"
            : $"{ts.Minutes}:{ts.Seconds:D2}";
    }

    private static string FormatBytes(long bytes)
    {
        return bytes switch
        {
            >= 1_073_741_824 => $"{bytes / 1_073_741_824.0:F1}GB",
            >= 1_048_576 => $"{bytes / 1_048_576.0:F1}MB",
            >= 1024 => $"{bytes / 1024.0:F1}KB",
            _ => $"{bytes}B"
        };
    }
}
